# Base URL for the squadhub.in public API that serves landing-page content.
# Example: https://api.squadhub.in
NEXT_PUBLIC_SQUADHUB_API_URL=

# Set to 1 to use the local landing-page fixture instead of hitting the API.
# Useful for local development when squadhub.in doesn't yet have the landing page.
NEXT_PUBLIC_LANDING_FIXTURE=0
