<%- include('_header', { admin, title: 'Languages — UpSquad Admin' }) %>
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold">Languages</h1>
    <p class="text-sm text-slate-500 mt-1">Languages defined here can be used on any landing page.</p>
  </div>
</div>

<div class="bg-white border border-gray-200 rounded-xl p-6 mb-6">
  <h2 class="text-sm font-semibold mb-3">Add a language</h2>
  <% if (error) { %>
    <div class="mb-3 px-3 py-2 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm"><%= error %></div>
  <% } %>
  <form method="POST" action="/admin/languages" class="flex items-end gap-3">
    <label class="flex-1">
      <span class="text-xs font-medium text-slate-600">Code <span class="text-slate-400">(e.g. en, hi, es)</span></span>
      <input name="code" required pattern="[a-zA-Z]{2,10}" class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm" />
    </label>
    <label class="flex-1">
      <span class="text-xs font-medium text-slate-600">Name</span>
      <input name="name" required class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm" />
    </label>
    <button class="bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium px-4 py-2 rounded-lg">Add</button>
  </form>
</div>

<div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-slate-500 text-xs uppercase">
      <tr>
        <th class="text-left px-4 py-3">Code</th>
        <th class="text-left px-4 py-3">Name</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      <% if (languages.length === 0) { %>
        <tr><td colspan="3" class="px-4 py-6 text-center text-slate-500">No languages yet.</td></tr>
      <% } %>
      <% languages.forEach(function(l) { %>
        <tr class="border-t border-gray-100">
          <td class="px-4 py-3 font-mono text-xs uppercase"><%= l.code %></td>
          <td class="px-4 py-3"><%= l.name %></td>
          <td class="px-4 py-3 text-right">
            <form method="POST" action="/admin/languages/<%= l.code %>/delete" onsubmit="return confirm('Delete language <%= l.code %>? This also removes it from all landing pages.');" class="m-0">
              <button class="text-xs text-red-500 hover:text-red-700">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('_footer') %>
