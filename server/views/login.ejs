<%- include('_header', { admin: null, title: 'Sign in — UpSquad Admin' }) %>
<div class="max-w-sm mx-auto mt-16 bg-white border border-gray-200 rounded-2xl shadow-sm p-8">
  <h1 class="text-xl font-bold mb-1">UpSquad Admin</h1>
  <p class="text-sm text-slate-500 mb-6">Sign in to manage landing pages.</p>
  <% if (error) { %>
    <div class="mb-4 px-3 py-2 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm"><%= error %></div>
  <% } %>
  <form method="POST" action="/admin/login" class="space-y-4">
    <label class="block">
      <span class="text-xs font-medium text-slate-600">Email</span>
      <input name="email" type="email" required autofocus value="<%= email %>"
        class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500" />
    </label>
    <label class="block">
      <span class="text-xs font-medium text-slate-600">Password</span>
      <input name="password" type="password" required
        class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500" />
    </label>
    <button class="w-full bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium py-2 rounded-lg transition-colors">Sign in</button>
  </form>
</div>
<%- include('_footer') %>
