# Copy to server/.env.production on the VPS (do not commit).
# This file is loaded by docker-compose via env_file.

ADMIN_EMAIL=jeff@upsquadconnect.com
# Generate on the VPS after first deploy, then paste the hash here:
#   docker compose run --rm --entrypoint sh upsquad -c "node -e \"console.log(require('bcryptjs').hashSync('CHANGE_ME', 10))\""
ADMIN_PASSWORD_HASH=

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Public URL — used to build absolute URLs for uploaded media returned by the API.
PUBLIC_BASE_URL=https://www.upsquadconnect.com

# CORS — leave empty in prod. Express serves admin + API + static Next build
# from the same origin, so the landing page's API calls are same-origin and
# CORS isn't needed. Add origins here only if the landing page is hosted elsewhere.
CORS_ORIGINS=
